# Crypto Screener API Configuration
# Copy this file to .env and adjust values as needed.
# All variables use the SCREENER_ prefix.

# API server host and port
SCREENER_API_HOST=0.0.0.0
SCREENER_API_PORT=8000

# Cache TTL in seconds (how long data is considered fresh)
SCREENER_CACHE_TTL=60

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SCREENER_LOG_LEVEL=INFO

# Comma-separated list of symbols to track (CCXT futures format)
SCREENER_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,AAVE/USDT:USDT,LINK/USDT:USDT,AVAX/USDT:USDT,DOGE/USDT:USDT

# Enable mock mode for testing without exchange connectivity
SCREENER_MOCK_MODE=false

# CORS allowed origins (comma-separated, use * for all)
SCREENER_CORS_ORIGINS=*

# Graceful shutdown timeout in seconds
SCREENER_SHUTDOWN_TIMEOUT=30
