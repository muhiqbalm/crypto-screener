# Crypto Screener API Configuration
# Copy this file to .env and adjust values as needed.
# All variables use the SCREENER_ prefix.

# API server host and port
SCREENER_API_HOST=0.0.0.0
SCREENER_API_PORT=8000

# Cache TTL in seconds (how long data is considered fresh)
SCREENER_CACHE_TTL=60

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SCREENER_LOG_LEVEL=INFO

# Comma-separated list of symbols to track (CCXT futures format)
SCREENER_SYMBOLS=BTC/USDT:USDT,ETH/USDT:USDT,SOL/USDT:USDT,AAVE/USDT:USDT,LINK/USDT:USDT,AVAX/USDT:USDT,DOGE/USDT:USDT

# Enable mock mode for testing without exchange connectivity
SCREENER_MOCK_MODE=false

# CORS allowed origins (comma-separated, use * for all)
SCREENER_CORS_ORIGINS=*

# Graceful shutdown timeout in seconds
SCREENER_SHUTDOWN_TIMEOUT=30

# ── Global API Key Authentication ──────────────────────────
# When enabled, ALL endpoints (except /health) require X-API-Key header.
# Set to true for production; false for local testing.
SCREENER_REQUIRE_API_KEY=false
# The secret API key value. Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SCREENER_API_KEY=change-me-to-a-secure-random-string

# Debug API authentication (optional)
# Enable authentication for debug endpoints to protect sensitive exchange data
SCREENER_DEBUG_API_AUTH_ENABLED=false
# Bearer token for debug API authentication (required if auth is enabled)
SCREENER_DEBUG_API_AUTH_TOKEN=your-secret-token-here

# Rate limiting for debug endpoints (optional)
# Enable rate limiting to prevent abuse of debug endpoints
SCREENER_DEBUG_RATE_LIMIT_ENABLED=false
# Maximum number of requests allowed per time window
SCREENER_DEBUG_RATE_LIMIT_REQUESTS=10
# Time window in seconds for rate limiting
SCREENER_DEBUG_RATE_LIMIT_WINDOW=60

# ── Trading Module (TradingView Webhook) ──────────────────
# All variables use the TRADING_ prefix.

# Supabase project URL and service role key
TRADING_SUPABASE_URL=https://your-project.supabase.co
TRADING_SUPABASE_KEY=your-supabase-service-role-key

# Fernet encryption key for storing exchange API credentials.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TRADING_ENCRYPTION_KEY=your-fernet-encryption-key-here

# Telegram bot token for trade execution notifications (optional).
# Create a bot via @BotFather on Telegram.
TRADING_TELEGRAM_BOT_TOKEN=

# Use testnet/sandbox mode for all exchange connections (recommended: true in non-production)
TRADING_TESTNET_ENABLED=true

# Enable CCXT raw HTTP request/response logging (very noisy — debug only).
# When true, every CCXT call from connector instances will print headers,
# URL, body, and response to stderr.
TRADING_CCXT_VERBOSE=false

# Maximum webhook payload size in bytes (default: 1 MB = 1048576)
TRADING_MAX_PAYLOAD_SIZE=1048576

# Timeout in seconds for acquiring the database advisory lock per user-symbol pair
TRADING_LOCK_TIMEOUT_SECONDS=5

# Timeout in seconds for submitting an order to the exchange
TRADING_ORDER_TIMEOUT_SECONDS=5
